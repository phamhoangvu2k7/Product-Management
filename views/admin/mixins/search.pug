mixin search(keyword) 
    form(id="form-search")
        .search-box
            input(
                type="text"
                placeholder="Nhập từ khóa"
                name="keyword"
                class="form-control"
                value=keyword
            )
            button(
                class="btn"
                type="submit"
            )
                i.fa-solid.fa-magnifying-glass