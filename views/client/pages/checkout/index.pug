extends ../../layouts/default.pug
include ../../mixins/box-head.pug
include ../../mixins/alert.pug

block main
    +alert-success(5000)
    +alert-error(5000)

    .container.my-5
        .checkout-steps
            .checkout-step.done
                .step-num
                    i.fa-solid.fa-check
                | Cart
            .checkout-step.active
                .step-num 2
                | Order Info
            .checkout-step
                .step-num 3
                | Complete

        +box-head("Place Order")

        if (cartDetail.products.length > 0)
            .table-card.mb-4
                table.table
                    thead
                        tr
                            th #
                            th Product
                            th Price
                            th Qty
                            th Total
                    tbody
                        each item, index in cartDetail.products
                            tr
                                td #{index + 1}
                                td
                                    .d-flex.align-items-center(style="gap: 12px;")
                                        img(
                                            src=item.productInfo.thumbnail || '/uploads/seed/no-image.svg'
                                            alt=item.productInfo.title
                                            width="56"
                                            height="56"
                                            style="object-fit: cover; border-radius: 8px;"
                                            loading="lazy"
                                        )
                                        span #{item.productInfo.title}
                                td #{item.productInfo.priceNew}$
                                td #{item.quantity}
                                td
                                    b(style="color: var(--primary); font-family: 'JetBrains Mono', monospace;") #{item.totalPrice}$

            .order-total.mb-4
                .label Total Order
                .amount #{cartDetail.totalPrice}$

            .form-card
                h2
                    i.fa-solid.fa-truck.mr-2
                    | Shipping Information
                form(action="/checkout/order" method="POST")
                    .form-group
                        label(for="fullName") Full Name
                        input.form-control(
                            type="text"
                            id="fullName"
                            name="fullName"
                            placeholder="Enter your full name"
                            required
                        )
                    .form-group
                        label(for="phone") Phone
                        input.form-control(
                            type="tel"
                            id="phone"
                            name="phone"
                            placeholder="Enter phone number"
                            required
                        )
                    .form-group
                        label(for="address") Address
                        input.form-control(
                            type="text"
                            id="address"
                            name="address"
                            placeholder="Enter delivery address"
                            required
                        )
                    button.btn.btn-success.btn-lg.btn-block(type="submit")
                        i.fa-solid.fa-check.mr-2
                        | Place Order
        else
            .empty-state
                i.fa-solid.fa-cart-shopping
                p Your cart is empty.
                a.btn.btn-primary.mt-3(href="/products") Shop Now
