extends ../../layouts/default.pug
include ../../mixins/box-head.pug

block main
    .container.my-5
        .checkout-steps.mb-5
            .checkout-step.done
                .step-num
                    i.fa-solid.fa-check
                | Cart
            .checkout-step.done
                .step-num
                    i.fa-solid.fa-check
                | Order Info
            .checkout-step.active
                .step-num 3
                | Complete

        .success-banner
            i.fa-solid.fa-circle-check
            h3 Order Placed Successfully!
            p We'll process your order as soon as possible. Thank you!

        if (order)
            .form-card.mb-4
                h2
                    i.fa-solid.fa-user.mr-2
                    | Shipping Info
                .user-info-card(style="box-shadow: none; border: none; padding: 0;")
                    .info-row
                        .info-label Full Name
                        .info-value #{order.userInfo.fullName}
                    .info-row
                        .info-label Phone
                        .info-value #{order.userInfo.phone}
                    .info-row
                        .info-label Address
                        .info-value #{order.userInfo.address}

            +box-head("Order Summary")
            .table-card
                table.table
                    thead
                        tr
                            th #
                            th Product
                            th Price
                            th Qty
                            th Total
                    tbody
                        if (order.products.length > 0)
                            each item, index in order.products
                                tr
                                    td #{index + 1}
                                    td
                                        .d-flex.align-items-center(style="gap: 12px;")
                                            img(
                                                src=item.productInfo.thumbnail || '/uploads/seed/no-image.svg'
                                                alt=item.productInfo.title
                                                width="56"
                                                height="56"
                                                style="object-fit: cover; border-radius: 8px;"
                                                loading="lazy"
                                            )
                                            span #{item.productInfo.title}
                                    td(style="font-family: 'JetBrains Mono', monospace;") #{item.priceNew}$
                                    td #{item.quantity}
                                    td
                                        b(style="color: var(--primary); font-family: 'JetBrains Mono', monospace;") #{item.totalPrice}$

            if (order.products.length > 0)
                .order-total
                    .label Total
                    .amount #{order.totalPrice}$

        .text-center.mt-5
            a.btn-cta(href="/")
                i.fa-solid.fa-house(style="font-size: 13px;")
                | Back to Home
