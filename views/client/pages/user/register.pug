extends ../../layouts/default.pug
include ../../mixins/alert.pug

block main
    +alert-error(5000)

    .container.my-5
        .row.justify-content-center
            .col-md-6.col-lg-5
                .form-card
                    .text-center.mb-4
                        i.fa-solid.fa-user-plus(style="font-size: 36px; color: var(--primary);")
                    h1.text-center Đăng ký tài khoản
                    form(action="/user/register" method="POST")
                        .form-group
                            label(for="fullName") Họ và tên
                            input.form-control(
                                type="text"
                                id="fullName"
                                name="fullName"
                                placeholder="Nhập họ và tên"
                                required
                            )
                        .form-group
                            label(for="email") Email
                            input.form-control(
                                type="email"
                                id="email"
                                name="email"
                                placeholder="name@example.com"
                                required
                            )
                        .form-group
                            label(for="password") Mật khẩu
                            input.form-control(
                                type="password"
                                id="password"
                                name="password"
                                placeholder="Nhập mật khẩu"
                                required
                            )
                        button.btn.btn-primary.btn-block.btn-lg.mt-3(type="submit") Đăng ký

                    .text-center.mt-3
                        span(style="font-size: 14px; color: var(--text-muted);") Đã có tài khoản?&nbsp;
                        a(href="/user/login" style="font-size: 14px; font-weight: 600;") Đăng nhập
