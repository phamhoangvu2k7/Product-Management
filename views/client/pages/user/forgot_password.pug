extends ../../layouts/default.pug
include ../../mixins/alert.pug

block main
    +alert-error(5000)

    .container.my-5
        .row.justify-content-center
            .col-md-6.col-lg-5
                .form-card
                    .text-center.mb-4
                        i.fa-solid.fa-lock(style="font-size: 36px; color: var(--primary);")
                    h1.text-center Lấy lại mật khẩu
                    p.text-center(style="color: var(--text-muted); font-size: 14px; margin-bottom: 24px;") Nhập email để nhận mã xác nhận
                    form(action="/user/password/forgot" method="POST")
                        .form-group
                            label(for="email") Email
                            input.form-control(
                                type="email"
                                id="email"
                                name="email"
                                placeholder="name@example.com"
                                required
                            )
                        button.btn.btn-primary.btn-block.btn-lg.mt-3(type="submit") Gửi mail xác nhận

                    .text-center.mt-3
                        a(href="/user/login" style="font-size: 14px;")
                            i.fa-solid.fa-arrow-left.mr-1
                            | Quay lại đăng nhập
