extends ../../layouts/default.pug
include ../../mixins/alert.pug

block main
    +alert-error(5000)

    .auth-page
        .form-card
            .auth-logo
                .brand-name PM Store
            .auth-icon
                i.fa-solid.fa-lock
            h1.text-center Forgot Password
            p.text-center(style="color: var(--text-muted); font-size: 14px; margin-bottom: 24px;") Enter your email to receive a verification code
            form(action="/user/password/forgot" method="POST")
                .form-group
                    label(for="email") Email
                    input.form-control(
                        type="email"
                        id="email"
                        name="email"
                        placeholder="name@example.com"
                        required
                    )
                button.btn.btn-primary.btn-block.btn-lg.mt-3(type="submit") Send Reset Email

            .text-center.mt-3
                a(href="/user/login" style="font-size: 14px; color: var(--text-muted);")
                    i.fa-solid.fa-arrow-left.mr-1
                    | Back to Login
