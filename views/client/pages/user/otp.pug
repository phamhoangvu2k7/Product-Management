extends ../../layouts/default.pug
include ../../mixins/alert.pug

block main
    +alert-error(5000)

    .container.my-5
        .row.justify-content-center
            .col-md-6.col-lg-5
                .form-card
                    .text-center.mb-4
                        i.fa-solid.fa-shield-halved(style="font-size: 36px; color: var(--primary);")
                    h1.text-center Xác thực OTP
                    p.text-center(style="color: var(--text-muted); font-size: 14px; margin-bottom: 24px;") Nhập mã OTP đã gửi tới email của bạn
                    form(action="/user/password/otp" method="POST")
                        .form-group
                            label(for="email") Email
                            input.form-control(
                                type="email"
                                id="email"
                                name="email"
                                value=email
                                readonly
                                required
                                style="background: var(--bg);"
                            )
                        .form-group
                            label(for="otp") Mã OTP
                            input.form-control(
                                type="text"
                                id="otp"
                                name="otp"
                                placeholder="Nhập mã OTP"
                                required
                                style="text-align: center; font-size: 20px; letter-spacing: 8px; font-weight: 700;"
                            )
                        button.btn.btn-primary.btn-block.btn-lg.mt-3(type="submit") Xác nhận
