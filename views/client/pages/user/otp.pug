extends ../../layouts/default.pug
include ../../mixins/alert.pug

block main
    +alert-error(5000)

    .auth-page
        .form-card
            .auth-logo
                .brand-name PM Store
            .auth-icon
                i.fa-solid.fa-shield-halved
            h1.text-center Verify OTP
            p.text-center(style="color: var(--text-muted); font-size: 14px; margin-bottom: 24px;") Enter the OTP code sent to your email
            form(action="/user/password/otp" method="POST")
                .form-group
                    label(for="email") Email
                    input.form-control(
                        type="email"
                        id="email"
                        name="email"
                        value=email
                        readonly
                        required
                        style="opacity: 0.6; cursor: not-allowed;"
                    )
                .form-group
                    label(for="otp") OTP Code
                    input.form-control(
                        type="text"
                        id="otp"
                        name="otp"
                        placeholder="• • • • • •"
                        required
                        style="text-align: center; font-size: 22px; letter-spacing: 10px; font-weight: 700; font-family: 'JetBrains Mono', monospace;"
                    )
                button.btn.btn-primary.btn-block.btn-lg.mt-3(type="submit") Verify
