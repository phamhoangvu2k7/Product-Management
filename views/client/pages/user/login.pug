extends ../../layouts/default.pug
include ../../mixins/alert.pug

block main
    +alert-error(5000)

    .container.my-5
        .row.justify-content-center
            .col-md-6.col-lg-5
                .form-card
                    .text-center.mb-4
                        i.fa-solid.fa-right-to-bracket(style="font-size: 36px; color: var(--primary);")
                    h1.text-center Đăng nhập
                    form(action="/user/login" method="POST")
                        .form-group
                            label(for="email") Email
                            input.form-control(
                                type="email"
                                id="email"
                                name="email"
                                placeholder="name@example.com"
                                required
                            )
                        .form-group
                            label(for="password") Mật khẩu
                            input.form-control(
                                type="password"
                                id="password"
                                name="password"
                                placeholder="Nhập mật khẩu"
                                required
                            )
                        button.btn.btn-primary.btn-block.btn-lg.mt-3(type="submit") Đăng nhập

                    .text-center.mt-3
                        a(href="/user/password/forgot" style="font-size: 14px;") Quên mật khẩu?
                    .text-center.mt-2
                        span(style="font-size: 14px; color: var(--text-muted);") Chưa có tài khoản?&nbsp;
                        a(href="/user/register" style="font-size: 14px; font-weight: 600;") Đăng ký
