extends ../../layouts/default.pug
include ../../mixins/alert.pug

block main
    +alert-error(5000)

    .auth-page
        .form-card
            .auth-logo
                .brand-name PM Store
            .auth-icon
                i.fa-solid.fa-right-to-bracket
            h1.text-center Login
            form(action="/user/login" method="POST")
                .form-group
                    label(for="email") Email
                    input.form-control(
                        type="email"
                        id="email"
                        name="email"
                        placeholder="name@example.com"
                        required
                    )
                .form-group
                    label(for="password") Password
                    input.form-control(
                        type="password"
                        id="password"
                        name="password"
                        placeholder="Enter your password"
                        required
                    )
                button.btn.btn-primary.btn-block.btn-lg.mt-3(type="submit") Login

            .text-center.mt-3
                a(href="/user/password/forgot" style="font-size: 14px; color: var(--text-muted);") Forgot password?
            .text-center.mt-2
                span(style="font-size: 14px; color: var(--text-muted);") Don't have an account?&nbsp;
                a(href="/user/register" style="font-size: 14px; font-weight: 700; color: var(--primary);") Register
