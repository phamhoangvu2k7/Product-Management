include ../mixins/alert.pug

doctype html
html(lang="en")
    head
        title #{pageTitle} | #{settingGeneral ? settingGeneral.websiteName : "PM Store"}
        meta(charset="utf-8")
        meta(name="viewport" content="width=device-width, initial-scale=1.0")
        meta(name="robots" content="index, follow")
        meta(name="description" content=pageDescription || (settingGeneral ? `Buy genuine laptops, smartphones, tablets at the best prices at ${settingGeneral.websiteName}.` : "PM Store - Genuine Electronics."))
        meta(name="keywords" content="laptop, smartphone, tablet, electronics, buy online")
        link(rel="canonical" href=`https://pmstore.com${currentPath || '/'}`)

        //- Open Graph
        meta(property="og:title" content=`${pageTitle} | ${settingGeneral ? settingGeneral.websiteName : "PM Store"}`)
        meta(property="og:description" content=pageDescription || (settingGeneral ? settingGeneral.websiteName : "PM Store"))
        meta(property="og:type" content=ogType || "website")
        meta(property="og:url" content=`https://pmstore.com${currentPath || '/'}`)
        meta(property="og:image" content=ogImage || "/images/og-default.png")
        meta(property="og:site_name" content="PM Store")
        meta(property="og:locale" content="en_US")

        //- Twitter Card
        meta(name="twitter:card" content="summary_large_image")
        meta(name="twitter:title" content=`${pageTitle} | PM Store`)
        meta(name="twitter:description" content=pageDescription || "PM Store - Genuine Electronics")

        //- Favicon
        link(rel="icon" type="image/svg+xml" href="/images/favicon.svg")

        //- Preconnect for performance
        link(rel="preconnect" href="https://fonts.googleapis.com")
        link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin)

        link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css")
        link(rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css")
        link(rel="stylesheet" href="/css/style.css")

        block head
    body
        +alert-success(2000)

        include ../partials/header.pug

        main
            block main

        include ../partials/footer.pug

        script(src="https://cdn.jsdelivr.net/npm/jquery@3.5.1/dist/jquery.slim.min.js")
        script(src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js")
        script(src="/js/script.js")
        block scripts
